{
  "name": "VAMPIRE GAMES BOT",
  "description": "Premium Telegram Multiplayer Viral Games Bot with Economy, Fun Games & Chaos System",
  "logo": "https://i.imgur.com/yourdp.png",
  "keywords": [
    "telegram",
    "bot",
    "aiogram",
    "games",
    "multiplayer",
    "economy",
    "viral",
    "fun"
  ],
  "website": "https://github.com/VAMPIRE-BOTS/VAMPIRE-GAMES",
  "repository": "https://github.com/VAMPIRE-BOTS/VAMPIRE-GAMES",
  "success_url": "/",
  
  "env": {
    "BOT_TOKEN": {
      "description": "Your Telegram Bot Token from BotFather",
      "required": true
    },

    "OWNER_ID": {
      "description": "Your Telegram Numeric User ID",
      "required": true
    },

    "OWNER_USERNAME": {
      "description": "Your Telegram Username (without @)",
      "required": false
    },

    "MONGO_DB_URI": {
      "description": "MongoDB Database Connection URL",
      "required": true
    },

    "SUPPORT_GROUP": {
      "description": "Support Group Username (without @)",
      "required": false
    },

    "SUPPORT_CHANNEL": {
      "description": "Updates Channel Username (without @)",
      "required": false
    },

    "LOG_GROUP_ID": {
      "description": "Private Log Group ID (-100xxxxxxxxxx)",
      "required": false
    },

    "START_IMAGE": {
      "description": "Welcome Image URL for Start Message",
      "required": false
    }
  },

  "formation": {
    "worker": {
      "quantity": 1,
      "size": "basic"
    }
  },

  "buildpacks": [
    {
      "url": "heroku/python"
    }
  ]
}
